{
  "name": "Le Coffre - Full Stack Dev",
  "dockerComposeFile": "../docker-compose.dev.yml",
  "service": "devcontainer",
  "workspaceFolder": "/app",
  "forwardPorts": [8123, 8000, 5173],
  "remoteUser": "devuser",
  "initializeCommand": "echo USER_UID=$(id -u) > ${localWorkspaceFolder}/.env && echo USER_GID=$(id -g) >> ${localWorkspaceFolder}/.env",
  "postCreateCommand": "cd /app/server && uv sync && cd /app/frontend && bun install && bun x playwright install --with-deps chromium",
  "customizations": {
    "vscode": {
      "extensions": [
        // Python extensions
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        // Frontend extensions
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Vue.volar",
        // General extensions
        "qwtel.sqlite-viewer",
        "Gruntfuggly.todo-tree"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        // Python settings
        "python.defaultInterpreterPath": "/app/server/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.analysis.typeCheckingMode": "basic",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.fixAll.ruff": "explicit",
          }
        },
        "ruff.nativeServer": true,
        "ruff.configuration": "server/pyproject.toml",
        // TypeScript/JavaScript settings
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[vue]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
