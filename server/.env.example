# =============================================================================
# Environment Configuration — copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Runtime environment — set to "production" in production deployments
ENVIRONMENT=development

# Base URL of the application (used for building absolute URLs)
APP_BASE_URL=http://localhost:8123

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Database connection string
# SQLite (development):   sqlite:///local_db.sqlite
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///local_db.sqlite

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# REQUIRED in production — min 32 characters, keep secret
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# JWT signing algorithm (default: HS256)
JWT_ALGORITHM=HS256

# Access token expiration in minutes (default: 15)
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15

# Refresh token expiration in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# -----------------------------------------------------------------------------
# OpenTelemetry Monitoring (optional)
# -----------------------------------------------------------------------------

# Hard override to disable monitoring regardless of other settings (default: unset)
# Set to "false" to explicitly disable, "true" to force-enable (requires endpoint below)
# ENABLE_MONITORING=false

# OTLP collector endpoint — setting this activates monitoring automatically
# Example: http://otel-collector:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Service name reported to the OTLP collector (default: le-coffre)
# OTEL_SERVICE_NAME=le-coffre

# Additional resource attributes sent with every metric (optional)
# Format: key=value,key2=value2
# Example: k8s.namespace=prod,app.version=1.0.0
# OTEL_RESOURCE_ATTRIBUTES=
