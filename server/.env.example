# =============================================================================
# Environment Configuration — copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Runtime environment — set to "production" in production deployments
ENVIRONMENT=development

# Base URL of the application (used for building absolute URLs)
APP_BASE_URL=http://localhost:8123

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Database connection string
# SQLite (development):   sqlite:///local_db.sqlite
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///local_db.sqlite

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# REQUIRED in production — min 32 characters, keep secret
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# JWT signing algorithm (default: HS256)
JWT_ALGORITHM=HS256

# Access token expiration in minutes (default: 5)
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=5

# Refresh token expiration in hours (default: 4)
JWT_REFRESH_TOKEN_EXPIRATION_HOURS=4

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Enable or disable rate limiting (default: true)
RATE_LIMIT_ENABLED=true

# Sliding window duration in seconds (default: 60)
RATE_LIMIT_WINDOW_SECONDS=60

# Per-authenticated-user bucket — covers the normal UI + CLI automation
# once a user is logged in (default: 300)
RATE_LIMIT_USER_MAX_REQUESTS=300

# Per-IP bucket for unauthenticated callers — keeps pre-login traffic
# tight (default: 30)
RATE_LIMIT_UNAUTH_MAX_REQUESTS=30

# Per-IP volume floor on /api/auth/login — DoS protection for the one
# endpoint that submits credentials on every call (default: 100)
RATE_LIMIT_AUTH_MAX_REQUESTS=100

# Comma-separated TCP peer IPs whose X-Forwarded-For header is trusted.
# Default covers the standard nginx-on-same-host setup; expand for
# multi-hop proxy chains (CDN → nginx → backend, K8s ingress, etc.).
RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1,::1

# Number of trusted proxy hops between the client and the backend.
# Set to 2 if your CDN sits in front of nginx, etc. (default: 1)
RATE_LIMIT_TRUSTED_PROXY_HOPS=1

# -----------------------------------------------------------------------------
# Login Lockout
# -----------------------------------------------------------------------------

# Consecutive failed logins before an account is locked (default: 5)
LOGIN_MAX_FAILED_ATTEMPTS=5

# Duration in seconds an account stays locked after hitting the threshold
# (default: 300 = 5 minutes)
LOGIN_LOCKOUT_SECONDS=300

# -----------------------------------------------------------------------------
# OpenTelemetry Monitoring (optional)
# -----------------------------------------------------------------------------

# Hard override to disable monitoring regardless of other settings (default: unset)
# Set to "false" to explicitly disable, "true" to force-enable (requires endpoint below)
# ENABLE_MONITORING=false

# OTLP collector endpoint — setting this activates monitoring automatically
# Example: http://otel-collector:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Service name reported to the OTLP collector (default: le-coffre)
# OTEL_SERVICE_NAME=le-coffre

# Additional resource attributes sent with every metric (optional, override auto-detected values)
# Format: key=value,key2=value2
# Example: app.version=1.0.0,deployment.environment=production
# OTEL_RESOURCE_ATTRIBUTES=

# Kubernetes context — injected automatically when set via the downward API in your deployment:
#   env:
#     - name: POD_NAME
#       valueFrom: { fieldRef: { fieldPath: metadata.name } }
#     - name: NODE_NAME
#       valueFrom: { fieldRef: { fieldPath: spec.nodeName } }
#     - name: POD_NAMESPACE
#       valueFrom: { fieldRef: { fieldPath: metadata.namespace } }
# When present, these are automatically mapped to k8s.pod.name / k8s.node.name / k8s.namespace.name.
# POD_NAME=
# NODE_NAME=
# POD_NAMESPACE=

# Log format: set to "json" to emit structured JSON logs for log aggregation systems.
# Default: unset (standard uvicorn text format).
# LOG_FORMAT=json
