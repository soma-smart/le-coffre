{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Le Coffre Helm Chart Values",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "imagePullSecrets": { "type": "array" },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "updateStrategy": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["RollingUpdate", "Recreate"]
        }
      }
    },
    "frontend": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" },
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "resources": { "type": "object" },
        "securityContext": { "type": "object" },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          }
        },
        "podDisruptionBudget": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minAvailable": { "type": "integer", "minimum": 0 }
          }
        },
        "probes": { "type": "object" },
        "config": {
          "type": "object",
          "properties": {
            "apiBaseUrl": { "type": "string" }
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" },
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "resources": { "type": "object" },
        "securityContext": { "type": "object" },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
            "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          }
        },
        "podDisruptionBudget": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minAvailable": { "type": "integer", "minimum": 0 }
          }
        },
        "probes": { "type": "object" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["development", "production"]
        },
        "appBaseUrl": { "type": "string" },
        "database": {
          "type": "object",
          "properties": {
            "existingSecretName": { "type": "string" }
          },
          "required": ["existingSecretName"]
        },
        "jwt": {
          "type": "object",
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": ["HS256", "HS384", "HS512", "RS256", "RS384", "RS512"]
            },
            "accessTokenExpirationMinutes": { "type": "integer", "minimum": 1 },
            "refreshTokenExpirationHours": { "type": "integer", "minimum": 1 },
            "existingSecretName": { "type": "string" },
            "secretKey": { "type": "string" }
          }
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "authMaxRequests": { "type": "integer", "minimum": 1 },
            "apiMaxRequests": { "type": "integer", "minimum": 1 },
            "windowSeconds": { "type": "integer", "minimum": 1 }
          }
        },
        "logging": {
          "type": "object",
          "properties": {
            "format": { "type": "string" }
          }
        },
        "monitoring": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "otlpEndpoint": { "type": "string" },
            "serviceName": { "type": "string" },
            "tracesSampler": { "type": "string" },
            "tracesSamplerArg": { "type": "string" }
          }
        }
      },
      "required": ["environment", "appBaseUrl", "database", "jwt"]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "frontend": { "type": "object" },
        "backend": { "type": "object" }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessMode": {
          "type": "string",
          "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"]
        },
        "size": { "type": "string" },
        "mountPath": { "type": "string" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    }
  },
  "required": ["config"]
}
