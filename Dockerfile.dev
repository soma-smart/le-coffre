# Multi-stage unified development container for both frontend and backend
FROM ghcr.io/astral-sh/uv:python3.13-bookworm

# Install Node.js, Bun, nginx and other dependencies
RUN apt-get update && apt-get install -y \
    git \
    gh \
    bash \
    sudo \
    curl \
    unzip \
    nginx \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 24
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user first
ARG USER_UID=1000
ARG USER_GID=1000
ARG USERNAME=devuser

RUN groupadd -g $USER_GID $USERNAME \
    && useradd -u $USER_UID -g $USER_GID -m -s /bin/bash $USERNAME \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

# Install Bun globally for all users
RUN curl -fsSL https://bun.sh/install | bash
RUN mv /root/.bun/bin/bun /usr/local/bin/bun \
    && chmod +x /usr/local/bin/bun

# pre-commit baked into the image (not declared in server/pyproject.toml because
# it's a workspace-wide dev tool, not a backend dep). Installed via uv tool so
# it lives on PATH without venv activation. Both the launcher (UV_TOOL_BIN_DIR)
# and the backing venv (UV_TOOL_DIR) must be world-readable: by default uv
# installs into root's home (mode 700), so devuser hits "permission denied" when
# the launcher tries to exec the venv's python. Pinning UV_TOOL_DIR to /opt and
# chmod a+rX makes it usable for any UID compose remaps the runtime user to.
ENV UV_TOOL_BIN_DIR=/usr/local/bin \
    UV_TOOL_DIR=/opt/uv-tools
RUN uv tool install pre-commit --no-cache \
    && chmod -R a+rX /opt/uv-tools

# Set up workspace
WORKDIR /app

# Copy backend dependencies and install
COPY --chown=$USERNAME:$USERNAME server/pyproject.toml server/uv.lock /app/server/
RUN cd /app/server && uv sync --no-cache

# Copy frontend dependencies and install
COPY --chown=$USERNAME:$USERNAME frontend/package.json frontend/bun.lock /app/frontend/
WORKDIR /app/frontend
USER $USERNAME
RUN bun install

# Install Playwright + chromium at image-build time so a fresh container is
# usable immediately. PLAYWRIGHT_BROWSERS_PATH is set to a system-wide path so
# the browser cache survives the anonymous volume that compose mounts over
# /app/frontend/node_modules at runtime (which would otherwise hide the default
# ~/.cache/ms-playwright). --with-deps requires root for apt installs.
USER root
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
RUN mkdir -p $PLAYWRIGHT_BROWSERS_PATH \
    && cd /app/frontend && bun x playwright install --with-deps chromium \
    && chmod -R a+rX $PLAYWRIGHT_BROWSERS_PATH

WORKDIR /app

# Copy the rest of the application
COPY --chown=$USERNAME:$USERNAME . .

# Change ownership of the entire app directory
# Make node_modules and .venv world-writable so any container user (root in
# Codespaces, devuser locally) can install packages without sudo.
RUN chown -R $USERNAME:$USERNAME /app \
    && chmod -R a+w /app/frontend/node_modules /app/server/.venv

USER $USERNAME

CMD [ "tail", "-f", "/dev/null" ]
