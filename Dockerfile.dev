# Multi-stage unified development container for both frontend and backend
FROM ghcr.io/astral-sh/uv:python3.13-bookworm

# Install Node.js, Bun, nginx and other dependencies
RUN apt-get update && apt-get install -y \
    git \
    gh \
    bash \
    curl \
    unzip \
    nginx \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 24
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user first
ARG USER_UID=1000
ARG USER_GID=1000
ARG USERNAME=devuser

RUN groupadd -g $USER_GID $USERNAME \
    && useradd -u $USER_UID -g $USER_GID -m -s /bin/bash $USERNAME

# Install Bun globally for all users
RUN curl -fsSL https://bun.sh/install | bash
RUN mv /root/.bun/bin/bun /usr/local/bin/bun \
    && chmod +x /usr/local/bin/bun

# Set up workspace
WORKDIR /app

# Copy backend dependencies and install
COPY --chown=$USERNAME:$USERNAME server/pyproject.toml server/uv.lock /app/server/
RUN cd /app/server && uv sync --no-cache

# Copy frontend dependencies and install
COPY --chown=$USERNAME:$USERNAME frontend/package.json frontend/bun.lockb /app/frontend/
WORKDIR /app/frontend
USER $USERNAME
RUN bun install
USER root
WORKDIR /app

# Copy the rest of the application
COPY --chown=$USERNAME:$USERNAME . .

# Change ownership of the entire app directory
RUN chown -R $USERNAME:$USERNAME /app

USER $USERNAME

CMD [ "tail", "-f", "/dev/null" ]
