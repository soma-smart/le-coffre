# =============================================================================
# Optional — all variables below have sensible defaults for local development.
# Copy this file to .env and uncomment only what you want to override.
# =============================================================================

# Database (default: SQLite — no setup required)
# Switch to PostgreSQL for production-grade persistence:
# DATABASE_URL=postgresql://user:password@db:5432/le_coffre

# JWT secret key — auto-generated per session if not set (tokens lost on restart)
# Set a stable value if you want sessions to survive container restarts:
# JWT_SECRET_KEY=your-random-32-char-secret-here

# Base URL of the application (used for building absolute URLs)
# APP_BASE_URL=http://localhost
