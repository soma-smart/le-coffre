# =============================================================================
# Le Coffre — Docker Compose environment configuration
# Copy this file to .env and fill in the required values before running:
#   cp .env.example .env
#   docker compose up -d                        # external PostgreSQL
#   docker compose --profile postgres up -d     # bundled PostgreSQL
# =============================================================================

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=production

# External base URL of the application — used for SSO callbacks and CORS.
APP_BASE_URL=https://le-coffre.yourdomain.com

# =============================================================================
# Database
# =============================================================================
# External PostgreSQL (default) — fill in your managed database credentials:
DATABASE_URL=postgresql://user:password@db-host:5432/lecoffre?sslmode=require

# Bundled PostgreSQL (--profile postgres) — use this URL instead:
# REQUIRED when running: docker compose --profile postgres up -d
# POSTGRES_PASSWORD=changeme
# DATABASE_URL=postgresql://lecoffre:${POSTGRES_PASSWORD}@postgres:5432/lecoffre

# Tip: URL-encode special characters in the password:
#   python3 -c "import urllib.parse; print(urllib.parse.quote('your_password', safe=''))"

# =============================================================================
# JWT
# =============================================================================
# REQUIRED — generate with: openssl rand -base64 32
JWT_SECRET_KEY=

JWT_ALGORITHM=HS256
# Access token lifetime in minutes.
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
# Refresh token lifetime in hours.
JWT_REFRESH_TOKEN_EXPIRATION_HOURS=168

# =============================================================================
# Logging
# =============================================================================
# Set to "json" for structured log aggregation (recommended).
# Leave unset or empty for standard uvicorn text format.
LOG_FORMAT=json

# =============================================================================
# Rate limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
# Max requests per sliding window for auth routes (login, register, SSO).
RATE_LIMIT_AUTH_MAX_REQUESTS=5
# Max requests per sliding window for general API routes.
RATE_LIMIT_API_MAX_REQUESTS=60
# Sliding window duration in seconds.
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# Monitoring — OpenTelemetry OTLP (optional)
# =============================================================================
# Uncomment and configure to enable metrics, traces, and logs export.
#
# OTLP HTTP collector endpoint (/v1/metrics, /v1/traces, /v1/logs are appended).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
#
# Service name used as the job= label in Prometheus and in trace backends.
# OTEL_SERVICE_NAME=le-coffre
#
# Required for correct HTTP semantic conventions in OpenTelemetry SDK >= 1.21.
# OTEL_SEMCONV_STABILITY_OPT_IN=http
#
# Trace sampling strategy. Default (unset): parentbased_traceidratio at 5%.
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.05
#
# Bearer token for authenticated OTLP collectors (if required).
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>
